{
  "format_version": 2,
  "name": "UI Test \u2013 Full Analysis Report",
  "meta": {
    "legacy_id": "ui-test-full-analysis-report"
  },
  "steps": [
    {
      "name": "step_fetch",
      "expression": "fetch_channel_videos(channel_url=\"https://youtube.com/@mock_channel\")",
      "meta": {
        "label": "Fetch Videos",
        "legacy_step_id": "step-fetch"
      }
    },
    {
      "name": "step_metadata",
      "expression": "extract_metadata(video_url=step1)",
      "meta": {
        "label": "Extract Metadata",
        "legacy_step_id": "step-metadata"
      }
    },
    {
      "name": "step_transcribe",
      "expression": "transcribe_video(video_url=step1)",
      "meta": {
        "label": "Transcribe",
        "legacy_step_id": "step-transcribe"
      }
    },
    {
      "name": "step_segment",
      "expression": "segment_conversations(transcript=\"transcribe_video_output\")",
      "meta": {
        "label": "Segment Conversations",
        "legacy_step_id": "step-segment"
      }
    },
    {
      "name": "step_sentiment",
      "expression": "analyze_sentiment(text=\"segment_conversations_output\")",
      "meta": {
        "label": "Analyze Sentiment",
        "legacy_step_id": "step-sentiment"
      }
    }
  ]
}
