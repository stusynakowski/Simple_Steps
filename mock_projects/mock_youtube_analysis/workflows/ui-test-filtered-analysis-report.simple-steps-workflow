{
  "id": "ui-test-filtered-analysis-report",
  "name": "UI Test – Filtered Analysis Report",
  "created_at": "2026-04-26T12:00:00.000Z",
  "updated_at": "2026-04-27T00:00:00.000Z",
  "steps": [
    {
      "step_id": "step-fetch",
      "operation_id": "fetch_channel_videos",
      "label": "Fetch Videos",
      "config": {
        "channel_url": "https://youtube.com/@mock_channel",
        "_orchestrator": "source"
      },
      "formula": "=fetch_channel_videos.source(channel_url=\"https://youtube.com/@mock_channel\")"
    },
    {
      "step_id": "step-metadata",
      "operation_id": "extract_metadata",
      "label": "Extract Metadata",
      "config": {
        "_orchestrator": "map"
      },
      "formula": "=extract_metadata.map(video_url=step1.output)"
    },
    {
      "step_id": "step-filter",
      "operation_id": "filter_rows",
      "label": "Filter Popular (views > 50000)",
      "config": {
        "_orchestrator": "dataframe",
        "column": "views",
        "value": "50000",
        "mode": "greater_than"
      },
      "formula": "=filter_rows.dataframe(column=\"views\", value=\"50000\", mode=\"greater_than\")"
    },
    {
      "step_id": "step-transcribe",
      "operation_id": "transcribe_video",
      "label": "Transcribe",
      "config": {
        "_orchestrator": "map"
      },
      "formula": "=transcribe_video.map(video_url=step1.output)"
    },
    {
      "step_id": "step-segment",
      "operation_id": "segment_conversations",
      "label": "Segment Conversations",
      "config": {
        "_orchestrator": "expand",
        "transcript": "transcribe_video_output"
      },
      "formula": "=segment_conversations.expand(transcript=\"transcribe_video_output\")"
    },
    {
      "step_id": "step-sentiment",
      "operation_id": "analyze_sentiment",
      "label": "Analyze Sentiment",
      "config": {
        "_orchestrator": "map",
        "text": "segment_conversations_output"
      },
      "formula": "=analyze_sentiment.map(text=\"segment_conversations_output\")"
    }
  ]
}
